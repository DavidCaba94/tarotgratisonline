RewriteEngine on
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html

# ======================
# HUB ORACULOS
# ======================
RewriteRule ^oraculos$ /oraculos/oraculos.html [L]
RewriteRule ^oraculos-amor$ /oraculos/oraculos-amor.html [L]
