RewriteEngine on
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html

# ======================
# HUB ORACULOS
# ======================
RewriteRule ^oraculos$ /oraculos/oraculos.html [L]
RewriteRule ^oraculos-amor$ /oraculos/oraculos-amor.html [L]
RewriteRule ^oraculos-destino$ /oraculos/oraculos-destino.html [L]
RewriteRule ^oraculos-dinero$ /oraculos/oraculos-dinero.html [L]
RewriteRule ^oraculos-loteria$ /oraculos/oraculos-loteria.html [L]
RewriteRule ^oraculos-salud$ /oraculos/oraculos-salud.html [L]
RewriteRule ^oraculos-suerte$ /oraculos/oraculos-suerte.html [L]
RewriteRule ^oraculos-trabajo$ /oraculos/oraculos-trabajo.html [L]

