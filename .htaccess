RewriteEngine on

# ======================
# CANONICALIZACIÓN (HTTPS, no-www y URLs limpias)
# ======================
# Forzar HTTPS (compatible con proxies/CDN que usan X-Forwarded-Proto)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://tarotgratisonline.com%{REQUEST_URI} [R=301,L]

# Forzar dominio sin www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://tarotgratisonline.com%{REQUEST_URI} [R=301,L]

# /index.html -> raíz
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Subcarpetas: /ruta/index.html y /ruta/index -> /ruta/ (barra final canónica)
# Mantiene una única URL para las páginas servidas por index.html (p.ej. /compatibilidad-signos/aries/)
RewriteCond %{THE_REQUEST} \s/+(.+/)index(\.html)?[\s?] [NC]
RewriteRule ^(.+/)index(\.html)?$ /$1 [R=301,L]

# Rutas profundas de oráculos (/oraculos/vertical/slug.html) -> URL limpia /slug
RewriteCond %{THE_REQUEST} \s/+oraculos/[^/]+/[^/]+\.html[\s?] [NC]
RewriteRule ^oraculos/[^/]+/([^/]+)\.html$ /$1 [R=301,L]

# Hubs profundos (/oraculos/oraculos-x.html) -> /oraculos-x
RewriteCond %{THE_REQUEST} \s/+oraculos/oraculos-[^/]+\.html[\s?] [NC]
RewriteRule ^oraculos/(oraculos-[^/]+)\.html$ /$1 [R=301,L]

# Cualquier otra .html -> versión sin extensión (raíz y blog)
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# ======================
# REESCRITURA INTERNA (sirve la URL limpia desde el .html)
# ======================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html

# ======================
# HUB ORACULOS
# ======================
RewriteRule ^oraculos$ /oraculos/index.html [L]
RewriteRule ^oraculos-amor$ /oraculos/oraculos-amor.html [L]
RewriteRule ^oraculos-destino$ /oraculos/oraculos-destino.html [L]
RewriteRule ^oraculos-dinero$ /oraculos/oraculos-dinero.html [L]
